# Supabase Configuration
# Obtenha essas chaves em: https://app.supabase.com/project/bnfpcuzjvycudccycqqt/settings/api
SUPABASE_URL=https://bnfpcuzjvycudccycqqt.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Database URL (Supabase PostgreSQL)
# Obtenha em: https://app.supabase.com/project/bnfpcuzjvycudccycqqt/settings/database
# Format: postgresql://postgres.bnfpcuzjvycudccycqqt:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.bnfpcuzjvycudccycqqt:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Session Secret (gere uma chave aleatória segura)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# ═══════════════════════════════════════════════════════════════════════════════
# 🛡️ MODO DESENVOLVIMENTO - PROTEÇÃO DE SESSÕES WHATSAPP
# ═══════════════════════════════════════════════════════════════════════════════
# Defina como 'true' para rodar localhost SEM desconectar sessões do Railway
# Isso bloqueia conexões WhatsApp localmente, mas permite testar todo o resto
# 
# ⚠️  IMPORTANTE: Use 'true' quando for apenas editar código/testar interface
# ⚠️  Use 'false' ou remova se precisar testar funcionalidades do WhatsApp local
# ═══════════════════════════════════════════════════════════════════════════════
SKIP_WHATSAPP_RESTORE=true

# ═══════════════════════════════════════════════════════════════════════════════
# 🚫 DESABILITAR PROCESSAMENTO DE MENSAGENS WHATSAPP
# ═══════════════════════════════════════════════════════════════════════════════
# Quando Railway está rodando em produção e você quer desenvolver em localhost
# sem conflitos de mensagens duplicadas no banco de dados.
#
# Se 'true': localhost NÃO processa/salva mensagens (só Railway processa)
# Se 'false' ou não definido: localhost processa mensagens normalmente
#
# ⚠️  USE JUNTO COM SKIP_WHATSAPP_RESTORE=true para máxima proteção!
# ═══════════════════════════════════════════════════════════════════════════════
DISABLE_WHATSAPP_PROCESSING=true

# Mistral API (também configurável via Admin Panel)
MISTRAL_API_KEY=your-mistral-key

# Port
PORT=5000

# Node Environment
NODE_ENV=development

